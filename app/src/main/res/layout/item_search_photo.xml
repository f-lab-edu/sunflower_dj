<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <com.djyoo.sunflower.common.widget.CustomRoundLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/item_card_bg"
        app:bottom_left_corner_radius="20dp"
        app:bottom_right_corner_radius="20dp"
        app:top_left_corner_radius="20dp"
        app:top_right_corner_radius="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/search_photo_image"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:scaleType="centerCrop"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/search_photo_user_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:padding="12dp"
                android:singleLine="true"
                android:textColor="@color/item_card_text"
                android:textSize="14sp"
                tools:text="Tobi" />

        </LinearLayout>

    </com.djyoo.sunflower.common.widget.CustomRoundLayout>
</layout>
