<?xml version="1.0" encoding="utf-8"?>

<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.djyoo.sunflower.common.widget.CustomRoundLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/color_434E3E"
            app:bottom_left_corner_radius="20dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:top_right_corner_radius="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/garden_plant_image"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:scaleType="centerCrop"
                    tools:src="@tools:sample/backgrounds/scenic" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp">

                    <TextView
                        android:id="@+id/garden_plant_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:textColor="@color/color_BFC4B9"
                        android:textSize="18dp"
                        android:textStyle="bold"
                        tools:text="Cilantro" />

                    <TextView
                        android:id="@+id/garden_planted_label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:text="Planted"
                        android:textColor="@color/color_BFC4B9"
                        android:textSize="14dp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/garden_planted_date"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:gravity="center"
                        android:textColor="@color/color_BFC4B9"
                        android:textSize="14dp"
                        tools:text="Mar 9, 2026" />

                    <TextView
                        android:id="@+id/garden_last_watered_label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:text="Last Watered"
                        android:textColor="@color/color_BFC4B9"
                        android:textSize="14dp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/garden_last_watered_date"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:gravity="center"
                        android:textColor="@color/color_BFC4B9"
                        android:textSize="14dp"
                        tools:text="Mar 9, 2026" />

                    <TextView
                        android:id="@+id/garden_watering_message"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:layout_marginBottom="4dp"
                        android:gravity="center"
                        android:textColor="@color/color_BFC4B9"
                        android:textSize="14dp"
                        tools:text="water in 2 days." />
                </LinearLayout>

            </LinearLayout>

        </com.djyoo.sunflower.common.widget.CustomRoundLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
