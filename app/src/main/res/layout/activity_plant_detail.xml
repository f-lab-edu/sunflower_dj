<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/plant_detail_bg">

        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/detail_app_bar"
            android:layout_width="match_parent"
            android:layout_height="280dp"
            android:theme="@style/ThemeOverlay.Sunflower.PlantDetail.AppBar">

            <com.google.android.material.appbar.CollapsingToolbarLayout
                android:id="@+id/detail_collapsing_toolbar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:collapsedTitleGravity="center_horizontal|center_vertical"
                app:contentScrim="@color/plant_detail_bg"
                app:expandedTitleGravity="bottom"
                app:layout_scrollFlags="scroll|exitUntilCollapsed"
                app:titleEnabled="true">

                <ImageView
                    android:id="@+id/detail_image"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@null"
                    android:fitsSystemWindows="true"
                    android:scaleType="centerCrop"
                    app:layout_collapseMode="parallax"
                    app:layout_collapseParallaxMultiplier="0.5" />

                <androidx.appcompat.widget.Toolbar
                    android:id="@+id/detail_toolbar"
                    android:layout_width="match_parent"
                    android:layout_height="?attr/actionBarSize"
                    android:background="@android:color/transparent"
                    app:layout_collapseMode="pin">

                    <!-- 둥근 배경이 있는 백 버튼 -->
                    <ImageButton
                        android:id="@+id/detail_back_button"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="start|center_vertical"
                        android:layout_marginStart="16dp"
                        android:background="@drawable/bg_round_icon"
                        android:contentDescription="@string/title_plant_list"
                        android:padding="8dp"
                        android:scaleType="centerInside"
                        android:src="@android:drawable/ic_menu_revert"
                        android:tint="@color/plant_detail_text"
                        tools:ignore="UseAppTint" />

                    <!-- 둥근 배경이 있는 공유 버튼 -->
                    <ImageButton
                        android:id="@+id/detail_share_button"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="16dp"
                        android:background="@drawable/bg_round_icon"
                        android:contentDescription="@string/share"
                        android:padding="8dp"
                        android:scaleType="centerInside"
                        android:src="@android:drawable/ic_menu_share"
                        android:tint="@color/plant_detail_text"
                        tools:ignore="UseAppTint" />

                </androidx.appcompat.widget.Toolbar>

            </com.google.android.material.appbar.CollapsingToolbarLayout>
        </com.google.android.material.appbar.AppBarLayout>

        <com.djyoo.sunflower.common.widget.CustomRoundLayout
            android:id="@+id/detail_add_button"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="24dp"
            android:background="@color/bg_add_plant"
            android:contentDescription="@string/add_plant"
            android:gravity="center"
            android:visibility="gone"
            app:bottom_left_corner_radius="15dp"
            app:layout_anchor="@id/detail_app_bar"
            app:layout_anchorGravity="bottom|end"
            app:top_right_corner_radius="15dp">

            <ImageView
                android:id="@+id/detail_add_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_input_add"
                android:tint="@color/color_add_plant"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:ignore="UseAppTint" />
        </com.djyoo.sunflower.common.widget.CustomRoundLayout>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/detail_scroll_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:id="@+id/detail_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="@color/plant_detail_text"
                    android:textSize="28dp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/detail_watering_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="16dp"
                    android:text="@string/watering_needs"
                    android:textColor="@color/plant_detail_text"
                    android:textSize="14dp" />

                <TextView
                    android:id="@+id/detail_watering_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/plant_detail_secondary"
                    android:textSize="14dp" />

                <TextView
                    android:id="@+id/detail_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:lineSpacingExtra="4dp"
                    android:textColor="@color/plant_detail_text"
                    android:textColorLink="@color/color_4caf50"
                    android:textSize="14dp" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</layout>
