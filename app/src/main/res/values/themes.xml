<resources>
    <!-- Base application theme. -->
    <style name="Theme.Sunflower" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- 라이트 모드: 액티비티 배경 흰색 -->
        <item name="android:windowBackground">@color/white</item>
        <!-- Status bar: edge-to-edge로 액티비티 배경이 보이도록 투명 처리 -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <!-- 라이트 배경이므로 status bar 아이콘/텍스트를 어두운 색으로 표시 -->
        <item name="android:windowLightStatusBar">true</item>
        <!-- Customize your theme here. -->
    </style>

    <!-- Plant detail AppBar: 라이트 모드 → 어두운 아이콘 -->
    <style name="ThemeOverlay.Sunflower.PlantDetail.AppBar" parent="ThemeOverlay.AppCompat.Light" />

    <!-- SplashScreen API용 런처 테마 -->
    <style name="Theme.Sunflower.Splash" parent="Theme.Sunflower">
        <!-- 시스템 스플래시 배경색 -->
        <item name="windowSplashScreenBackground">@color/bg_splash</item>
        <!-- 중앙에 표시할 앱 아이콘 (적응형 런처 아이콘 사용) -->
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <!-- 스플래시 이후에 적용할 실제 앱 테마 -->
        <item name="postSplashScreenTheme">@style/Theme.Sunflower</item>
    </style>
</resources>